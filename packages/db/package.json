{
  "name": "@zhblogs/db",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "pnpm -F @zhblogs/utils run build && tsdown",
    "dev": "drizzle-kit studio",
    "drizzle": "drizzle-kit",
    "format": "prettier --config ./prettier.config.ts --write \"package.json\" \"*.ts\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --config ./prettier.config.ts --check \"package.json\" \"*.ts\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "generate": "drizzle-kit generate",
    "lint": "eslint --config ./eslint.config.ts \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\"",
    "lint:fix": "eslint --config ./eslint.config.ts \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" --fix",
    "migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    },
    "./schema": {
      "types": "./dist/schema/index.d.mts",
      "import": "./dist/schema/index.mjs"
    },
    "./schema/*": {
      "types": "./dist/schema/*.d.mts",
      "import": "./dist/schema/*.mjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.mts",
      "import": "./dist/constants/index.mjs"
    },
    "./constants/*": {
      "types": "./dist/constants/*.d.mts",
      "import": "./dist/constants/*.mjs"
    },
    "./zod": {
      "types": "./dist/zod/index.d.mts",
      "import": "./dist/zod/index.mjs"
    }
  },
  "dependencies": {
    "@zhblogs/configs": "workspace:*",
    "@zhblogs/utils": "workspace:*",
    "drizzle-orm": "^0.44.5",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.16.3",
    "uuid": "^13.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
