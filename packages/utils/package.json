{
  "name": "@zhblogs/utils",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsdown",
    "format": "prettier --config ./prettier.config.ts --write \"package.json\" \"*.ts\" \"src/**/*.ts\"",
    "format:check": "prettier --config ./prettier.config.ts --check \"package.json\" \"*.ts\" \"src/**/*.ts\"",
    "lint": "eslint --config ./eslint.config.ts \"src/**/*.ts\" \"*.ts\"",
    "lint:fix": "eslint --config ./eslint.config.ts \"src/**/*.ts\" \"*.ts\" --fix",
    "psl:update-rules": "tsx ./src/psl/update-rules.ts",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./psl": {
      "types": "./dist/psl/index.d.mts",
      "import": "./dist/psl/index.mjs"
    }
  },
  "devDependencies": {
    "@zhblogs/configs": "workspace:*"
  },
  "dependencies": {
    "@types/punycode": "^2.1.4",
    "punycode": "^2.3.1"
  }
}
