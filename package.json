{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "dotenv -e .env.prod -- pnpm run build:packages && dotenv -e .env.prod -- pnpm -F @zhblogs/api -F @zhblogs/web run build",
    "build:api": "dotenv -e .env.prod -- pnpm run build:packages && dotenv -e .env.prod -- pnpm -F @zhblogs/api run build",
    "build:packages": "pnpm --filter @zhblogs/db --filter @zhblogs/utils --if-present run build",
    "build:web": "dotenv -e .env.prod -- pnpm run build:packages && dotenv -e .env.prod -- pnpm -F @zhblogs/web run build",
    "commit:lint": "commitlint --from HEAD~1 --to HEAD",
    "db:generate": "pnpm -F @zhblogs/db drizzle generate",
    "db:migrate": "pnpm -F @zhblogs/db drizzle migrate",
    "db:studio": "pnpm -F @zhblogs/db drizzle studio",
    "dev": "dotenv -e .env.dev -- pnpm run dev:app",
    "dev:api": "dotenv -e .env.dev -- pnpm -F @zhblogs/api run dev",
    "dev:app": "dotenv -e .env.dev -- pnpm --parallel -F @zhblogs/api -F @zhblogs/web run dev",
    "dev:web": "dotenv -e .env.dev -- pnpm -F @zhblogs/web run dev",
    "format": "pnpm -r --if-present run format",
    "format:check": "pnpm -r --if-present run format:check",
    "hooks:install": "node ./scripts/install-git-hooks.mjs",
    "hooks:pre-commit": "node ./scripts/pre-commit.mjs",
    "lint": "pnpm -r --if-present run lint",
    "lint:fix": "pnpm -r --if-present run lint:fix",
    "prepare": "node ./scripts/install-git-hooks.mjs && pnpm run build:packages",
    "preview": "dotenv -e .env.prod -- pnpm --parallel -F @zhblogs/api -F @zhblogs/web run preview",
    "preview:api": "dotenv -e .env.prod -- pnpm -F @zhblogs/api run preview",
    "preview:app": "dotenv -e .env.prod -- pnpm --parallel -F @zhblogs/api -F @zhblogs/web run preview",
    "preview:web": "dotenv -e .env.prod -- pnpm -F @zhblogs/web run preview",
    "start": "dotenv -e .env.prod -- pnpm --parallel -F @zhblogs/api -F @zhblogs/web run start",
    "start:api": "dotenv -e .env.prod -- pnpm -F @zhblogs/api run start",
    "start:app": "dotenv -e .env.prod -- pnpm --parallel -F @zhblogs/api -F @zhblogs/web run start",
    "start:web": "dotenv -e .env.prod -- pnpm -F @zhblogs/web run start",
    "test": "dotenv -e .env.test -- pnpm run test:all",
    "test:all": "dotenv -e .env.test -- pnpm -r --if-present run test",
    "test:api": "dotenv -e .env.test -- pnpm -F @zhblogs/api run test",
    "test:web": "dotenv -e .env.test -- pnpm -F @zhblogs/web run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "util:psl:update-rules": "pnpm -F @zhblogs/utils run psl:update-rules"
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.7.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "astro-eslint-parser": "^1.4.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.16.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
