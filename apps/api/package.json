{
  "name": "@zhblogs/api",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch index.ts",
    "format": "prettier --config ./prettier.config.ts --write \"package.json\" \"*.ts\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --config ./prettier.config.ts --check \"package.json\" \"*.ts\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint --config ./eslint.config.ts \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\"",
    "lint:fix": "eslint --config ./eslint.config.ts \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" --fix",
    "preview": "node dist/index.mjs",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/oauth2": "^8.1.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@valkey/valkey-glide": "^2.2.7",
    "@zhblogs/configs": "workspace:*",
    "@zhblogs/db": "workspace:*",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "pino": "^9.9.5"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.2"
  }
}
