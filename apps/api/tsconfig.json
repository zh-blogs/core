{
  "extends": "@zhblogs/configs/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "lib": [
      "ESNext"
    ],
    "outDir": "dist",
    "sourceMap": true,
    "inlineSources": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}