---
const buildInfo = __ZHBLOGS_BUILD_METADATA__;

const formattedBuildTime = new Date(buildInfo.buildTime).toLocaleString("zh-CN", {
  hour12: false,
});

const formattedCommitTime = buildInfo.commitTime
  ? new Date(buildInfo.commitTime).toLocaleString("zh-CN", { hour12: false })
  : "unknown";

const summaryText = `v${buildInfo.version} · ${buildInfo.shortCommitHash}`;
---

<footer class="animate-in fade-in slide-in-from-bottom-2 duration-500 border-t border-slate-200/80 bg-white/70 backdrop-blur">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 py-4 text-sm text-slate-600 xs:px-5 sm:px-6 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-sm font-medium text-slate-900">ZhBlogs Web</p>
      <p class="mt-1 text-xs leading-6 text-slate-500">
        Build metadata is available from the footer summary.
      </p>
    </div>

    <div class="group relative w-full md:w-auto">
      <button
        aria-haspopup="dialog"
        class="inline-flex w-full items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-left text-sm font-medium text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-200 md:w-auto"
        type="button"
      >
        <span class="inline-flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          Build
        </span>
        <span class="font-mono text-xs text-slate-500">{summaryText}</span>
      </button>

      <div class="pointer-events-none absolute bottom-full left-0 z-20 mb-3 w-full translate-y-2 rounded-xl border border-slate-200 bg-white p-4 opacity-0 shadow-xl shadow-slate-900/10 transition duration-200 group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100 xs:w-80 md:left-auto md:right-0 md:w-96">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-slate-900">Build Details</p>
            <p class="mt-1 text-xs leading-5 text-slate-500">
              当前页脚默认只显示摘要，悬停后展开详细信息。
            </p>
          </div>
          <span class="rounded-lg bg-slate-100 px-2 py-1 font-mono text-[11px] text-slate-500">
            {buildInfo.branch}
          </span>
        </div>

        <dl class="mt-4 grid gap-3 text-sm">
          <div class="flex items-start justify-between gap-4 border-b border-slate-100 pb-3">
            <dt class="text-slate-500">Package</dt>
            <dd class="max-w-[70%] text-right font-medium text-slate-900">{buildInfo.packageName}</dd>
          </div>

          <div class="flex items-start justify-between gap-4 border-b border-slate-100 pb-3">
            <dt class="text-slate-500">Version</dt>
            <dd class="font-mono text-slate-900">v{buildInfo.version}</dd>
          </div>

          <div class="flex items-start justify-between gap-4 border-b border-slate-100 pb-3">
            <dt class="text-slate-500">Commit</dt>
            <dd class="text-right">
              {buildInfo.commitLink ? (
                <a
                  class="font-mono text-slate-900 underline decoration-slate-300 underline-offset-3 transition hover:text-slate-950"
                  href={buildInfo.commitLink}
                  rel="noreferrer"
                  target="_blank"
                >
                  {buildInfo.shortCommitHash}
                </a>
              ) : (
                <span class="font-mono text-slate-900">{buildInfo.shortCommitHash}</span>
              )}
            </dd>
          </div>

          <div class="flex items-start justify-between gap-4 border-b border-slate-100 pb-3">
            <dt class="text-slate-500">Build time</dt>
            <dd class="max-w-[70%] text-right text-slate-900">
              <time datetime={buildInfo.buildTime}>{formattedBuildTime}</time>
            </dd>
          </div>

          <div class="flex items-start justify-between gap-4">
            <dt class="text-slate-500">Commit time</dt>
            <dd class="max-w-[70%] text-right text-slate-900">
              <time datetime={buildInfo.commitTime || undefined}>{formattedCommitTime}</time>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</footer>
