---
type ManagedAnnouncement = {
  id: string;
  title: string;
  content: string | null;
  status: 'DRAFT' | 'SCHEDULED' | 'PUBLISHED' | 'EXPIRED';
  publishTime: string | null;
  expireTime: string | null;
  expiredTime: string | null;
  createdBy: string | null;
  updatedBy: string | null;
  createdTime: string;
  updatedTime: string;
};

type AnnouncementFormState = {
  id: string;
  title: string;
  content: string;
  status: ManagedAnnouncement['status'];
  publishTime: string;
  expireTime: string;
  scheduleEnabled: boolean;
  autoExpireEnabled: boolean;
};

type AnnouncementListItem = {
  entry: ManagedAnnouncement;
  formState: AnnouncementFormState;
  displayStatus: string;
  canArchive: boolean;
};

type PaginationView = {
  page: number;
  pageSize: number;
  totalItems: number;
  totalPages: number;
  previousHref: string | null;
  nextHref: string | null;
  pages: Array<{ page: number; href: string; isCurrent: boolean }>;
};

interface Props {
  items: AnnouncementListItem[];
  pagination: PaginationView;
}

const { items, pagination } = Astro.props;
---

<div class="surface-card">
  {
    items.length > 0 ? (
      <div class="divide-y divide-(--color-line)">
        {items.map(({ entry, formState, displayStatus, canArchive }) => (
          <article class="space-y-4 py-5 first:pt-0 last:pb-0">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="space-y-2">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="text-base font-medium text-(--color-fg)">{entry.title}</h3>
                  <span class="rounded-full border border-(--color-line-med) px-2.5 py-1 text-[11px] font-medium tracking-[0.12em] text-(--color-fg-3)">
                    {displayStatus}
                  </span>
                </div>
                <p class="text-xs leading-6 text-(--color-fg-3)">
                  发布时间：{entry.publishTime ?? '—'} ｜ 过期时间：{entry.expireTime ?? '—'} ｜
                  更新时间：
                  {entry.updatedTime}
                </p>
              </div>
              <div class="action-row">
                <button
                  class="action-button action-button-secondary"
                  data-announcement-edit-id={entry.id}
                  type="button"
                >
                  编辑
                </button>
                {entry.status === 'DRAFT' && (
                  <form action={`/management/announcements/${entry.id}/delete`} method="post">
                    <input name="page" type="hidden" value={pagination.page} />
                    <input name="pageSize" type="hidden" value={pagination.pageSize} />
                    <button class="action-button action-button-ghost" type="submit">
                      删除
                    </button>
                  </form>
                )}
                {canArchive && (
                  <form action={`/management/announcements/${entry.id}/archive`} method="post">
                    <input name="page" type="hidden" value={pagination.page} />
                    <input name="pageSize" type="hidden" value={pagination.pageSize} />
                    <button class="action-button action-button-ghost" type="submit">
                      归档
                    </button>
                  </form>
                )}
              </div>
            </div>

            {entry.content ? (
              <p class="whitespace-pre-wrap text-sm leading-7 text-(--color-fg-2)">
                {entry.content}
              </p>
            ) : (
              <p class="text-sm text-(--color-fg-3)">暂无正文内容。</p>
            )}

            <dl class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-(--color-fg-3)">
              <div class="flex items-center gap-2">
                <dt>创建时间</dt>
                <dd class="text-(--color-fg-2)">{entry.createdTime}</dd>
              </div>
              <div class="flex items-center gap-2">
                <dt>归档时间</dt>
                <dd class="text-(--color-fg-2)">{entry.expiredTime ?? '—'}</dd>
              </div>
            </dl>

            <script
              id={`announcement-record-${entry.id}`}
              is:inline
              type="application/json"
              set:html={JSON.stringify(formState)}
            />
          </article>
        ))}
      </div>
    ) : (
      <div class="rounded-sm border border-dashed border-(--color-line-med) p-6 text-sm text-(--color-fg-3)">
        还没有任何公告。
      </div>
    )
  }
</div>

{
  items.length > 0 && (
    <div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t border-(--color-line) pt-6">
      <p class="text-sm text-(--color-fg-3)">
        第 {pagination.page} / {pagination.totalPages} 页，共 {pagination.totalItems} 条
      </p>
      <div class="action-row">
        {pagination.previousHref ? (
          <a class="action-button action-button-ghost" href={pagination.previousHref}>
            上一页
          </a>
        ) : (
          <span class="action-button action-button-ghost" aria-disabled="true">
            上一页
          </span>
        )}

        {pagination.pages.map((pageItem) =>
          pageItem.isCurrent ? (
            <span class="action-button action-button-primary" aria-current="page">
              {pageItem.page}
            </span>
          ) : (
            <a class="action-button action-button-secondary" href={pageItem.href}>
              {pageItem.page}
            </a>
          ),
        )}

        {pagination.nextHref ? (
          <a class="action-button action-button-ghost" href={pagination.nextHref}>
            下一页
          </a>
        ) : (
          <span class="action-button action-button-ghost" aria-disabled="true">
            下一页
          </span>
        )}
      </div>
    </div>
  )
}
