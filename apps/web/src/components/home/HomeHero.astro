---
import type { Icon } from '@tabler/icons-svelte';
import IconArrowRight from '@tabler/icons-svelte/icons/arrow-right';
import IconNews from '@tabler/icons-svelte/icons/news';

const NewsIcon = IconNews as Icon;
const ArrowIcon = IconArrowRight as Icon;

interface Props {
  leadAnnouncement: {
    tag: string;
    title: string;
    summary: string;
    publishTime?: string | null;
  };
  leadAnnouncementDate: string;
  summary: {
    totalSites: number;
    featuredSites: number;
    todayUpdates: number;
  };
}

const { leadAnnouncement, leadAnnouncementDate, summary } = Astro.props;
---

<section
  class="grid gap-8 border-b border-(--color-line) pb-10 lg:grid-cols-[minmax(0,1fr)_28rem] lg:items-end"
  data-home-hero
>
  <div class="flex flex-col gap-5">
    <span
      class="inline-flex w-fit items-center gap-2 rounded-[999px] border border-red-700/18 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] text-red-700 dark:border-red-400/18 dark:text-red-400"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-red-700 dark:bg-red-400"></span>
      原中文博客列表导航
    </span>

    <div class="space-y-4">
      <h1
        class="font-serif max-w-[8ch] text-[clamp(3rem,8vw,4.5rem)] leading-none tracking-[-0.05em]"
      >
        集博栈
      </h1>
      <p class="max-w-160 text-[17px] leading-8 text-(--color-fg-2)">
        尝试收集并链接所有的个人博客站点
      </p>
    </div>

    <article
      class="inline-flex max-w-176 items-start gap-3 rounded-md border border-red-700/14 px-4 py-3 dark:border-red-400/30"
    >
      <span
        class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-(--color-line-med) text-red-700 dark:text-red-400"
      >
        <NewsIcon size={17} stroke={1.9} class="block" />
      </span>
      <span class="min-w-0 space-y-1">
        <span
          class="inline-flex flex-wrap items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-(--color-fg-3)"
        >
          <span>{leadAnnouncement.tag}</span>
          {leadAnnouncementDate ? <span>{leadAnnouncementDate}</span> : null}
        </span>
        <span class="block text-base font-medium text-(--color-fg)">{leadAnnouncement.title}</span>
        <span class="block text-sm leading-7 text-(--color-fg-2)">{leadAnnouncement.summary}</span>
      </span>
      <span class="mt-1 shrink-0 text-(--color-fg-3)">
        <NewsIcon size={15} stroke={1.9} class="block" />
      </span>
    </article>
  </div>

  <aside class="flex flex-col gap-5 lg:items-end">
    <a
      class="inline-flex items-center gap-2 text-sm font-medium text-(--color-fg-2) transition hover:text-red-700 dark:hover:text-red-400"
      href="/site/stats"
    >
      <span>统计信息</span>
      <ArrowIcon size={15} stroke={1.9} class="block" />
    </a>

    <dl class="grid w-full grid-cols-3 divide-x divide-(--color-line) lg:max-w-md">
      <div class="pr-4">
        <dt class="font-mono text-[11px] uppercase tracking-[0.16em] text-(--color-fg-3)">
          已收录博客
        </dt>
        <dd class="mt-3 text-[30px] leading-none font-medium tracking-[-0.04em] text-(--color-fg)">
          {summary.totalSites}
        </dd>
      </div>
      <div class="px-4">
        <dt class="font-mono text-[11px] uppercase tracking-[0.16em] text-(--color-fg-3)">
          精选博客
        </dt>
        <dd class="mt-3 text-[30px] leading-none font-medium tracking-[-0.04em] text-(--color-fg)">
          {summary.featuredSites}
        </dd>
      </div>
      <div class="pl-4">
        <dt class="font-mono text-[11px] uppercase tracking-[0.16em] text-(--color-fg-3)">
          当日更新
        </dt>
        <dd class="mt-3 text-[30px] leading-none font-medium tracking-[-0.04em] text-(--color-fg)">
          {summary.todayUpdates}
        </dd>
      </div>
    </dl>
  </aside>
</section>
