<section
  aria-atomic="false"
  aria-live="polite"
  class="pointer-events-none fixed inset-x-0 top-4 z-50 flex justify-center px-3.5 sm:top-5 sm:px-6"
  data-site-notice-root
>
  <div class="flex w-full max-w-[24rem] flex-col gap-3" data-site-notice-stack></div>
</section>

<template data-site-notice-template>
  <article
    class="site-notification pointer-events-auto relative overflow-hidden rounded-md border bg-(--color-bg-raised) p-4 text-left shadow-[0_18px_40px_rgba(28,25,23,0.14)] dark:shadow-[0_18px_40px_rgba(0,0,0,0.34)] sm:p-5"
    data-site-notice-item
    role="status"
  >
    <header class="flex items-start justify-between gap-3">
      <h2
        class="min-w-0 text-xl leading-tight tracking-[-0.03em] text-(--color-fg)"
        data-site-notice-title
      >
        通知
      </h2>

      <button
        aria-label="关闭通知"
        class="inline-flex h-6 w-6 shrink-0 items-center justify-center text-(--color-fg-3) transition hover:text-(--color-fg)"
        data-site-notice-close
        type="button"
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </header>

    <p class="text-sm leading-5 text-(--color-fg-2) pt-3" data-site-notice-message>通知内容</p>

    <div
      aria-hidden="true"
      class="site-notification-progress absolute inset-x-0 bottom-0 h-0.75"
      data-site-notice-progress
      hidden
    >
      <span
        class="site-notification-progress-bar block h-full origin-left"
        data-site-notice-progress-bar></span>
    </div>
  </article>
</template>

<script>
  import { initSiteNoticeCenter } from '@/application/site-notice/site-notice.browser';

  const stack = document.querySelector('[data-site-notice-stack]');
  const template = document.querySelector('[data-site-notice-template]');

  if (!(stack instanceof HTMLElement) || !(template instanceof HTMLTemplateElement)) {
    console.error('site notice stack is missing');
  } else {
    initSiteNoticeCenter(stack, template);
  }
</script>

<style>
  .site-notification {
    opacity: 0;
    transform: translateY(-10px);
    transition:
      opacity 180ms var(--ease-out-smooth),
      transform 220ms var(--ease-out-smooth);
  }

  .site-notification[data-state='open'] {
    opacity: 1;
    transform: translateY(0);
  }

  .site-notification[data-state='closing'] {
    opacity: 0;
    transform: translateY(-8px);
  }

  .site-notification-progress {
    background: var(--site-notice-accent-soft);
  }

  .site-notification-progress-bar {
    background: var(--site-notice-accent);
    animation-fill-mode: forwards;
    animation-timing-function: linear;
  }

  @keyframes site-notice-progress {
    from {
      transform: scaleX(1);
    }

    to {
      transform: scaleX(0);
    }
  }
</style>
