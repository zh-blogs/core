---
import {
  IconArrowRight,
  IconExternalLink,
  IconRss,
  IconSitemap,
  IconStarFilled,
} from '@tabler/icons-svelte-runes';

import type { PublicSiteEntry } from '@/application/site/site-public.server';

interface Props {
  entry: Pick<
    PublicSiteEntry,
    | 'slug'
    | 'name'
    | 'domain'
    | 'href'
    | 'shortCode'
    | 'primaryTag'
    | 'summary'
    | 'subTags'
    | 'joinedAt'
    | 'joinedLabel'
    | 'updatedLabel'
    | 'articleCount'
    | 'visitCount'
    | 'tone'
    | 'status'
    | 'rssUrl'
    | 'sitemapUrl'
    | 'featured'
  >;
}

type ResourceLink = {
  href: string;
  label: string;
  title: string;
  Icon: typeof IconArrowRight;
};

const { entry } = Astro.props as Props;
const ArrowIcon = IconArrowRight;
const ExternalLinkIcon = IconExternalLink;
const FeaturedIcon = IconStarFilled;
const RssIcon = IconRss;
const SitemapIcon = IconSitemap;
const detailHref = `/site/${entry.slug}`;
const toneClass = {
  amber: '[--card-accent:var(--color-warn)] [--card-accent-dot:var(--color-warn-dot)]',
  blue: '[--card-accent:var(--color-info)] [--card-accent-dot:var(--color-info-dot)]',
  emerald: '[--card-accent:var(--color-ok)] [--card-accent-dot:var(--color-ok-dot)]',
  red: '[--card-accent:var(--color-fail)] [--card-accent-dot:var(--color-fail-dot)]',
  stone: '[--card-accent:var(--color-fg-2)] [--card-accent-dot:var(--color-fg-3)]',
} satisfies Record<PublicSiteEntry['tone'], string>;

const statusClass = {
  fresh: '[--card-status-fg:var(--color-ok)] [--card-status-dot:var(--color-ok-dot)]',
  quiet: '[--card-status-fg:var(--color-fg-3)] [--card-status-dot:var(--color-fg-3)]',
  steady: '[--card-status-fg:var(--color-warn)] [--card-status-dot:var(--color-warn-dot)]',
} satisfies Record<PublicSiteEntry['status'], string>;

const resourceLinks: ResourceLink[] = [];

if (entry.rssUrl) {
  resourceLinks.push({
    href: entry.rssUrl,
    label: `${entry.name} RSS 订阅`,
    title: 'RSS 订阅',
    Icon: RssIcon,
  });
}

if (entry.sitemapUrl) {
  resourceLinks.push({
    href: entry.sitemapUrl,
    label: `${entry.name} 站点地图`,
    title: '站点地图',
    Icon: SitemapIcon,
  });
}

const metrics = [{ label: '访问', value: entry.visitCount }];

if (entry.articleCount) {
  metrics.push({ label: '文章', value: entry.articleCount });
}

const iconActionClass =
  'inline-flex size-6.5 items-center justify-center rounded-[3px] border border-[color:var(--color-line)] text-[color:var(--color-fg-3)] transition-[background-color,border-color,color] duration-150 ease-out-smooth hover:border-[color:color-mix(in_srgb,var(--card-accent)_24%,var(--color-line-med))] hover:bg-[color:var(--color-bg-raised)] hover:text-[color:var(--card-accent)] focus-visible:outline-none focus-visible:border-[color:var(--card-accent-dot)]';
const metricLabelClass =
  'font-mono text-[10px] leading-[1.2] tracking-[0.16em] text-[color:var(--color-fg-3)] uppercase';
const metricValueClass = 'mt-1 text-[14px] leading-[1.2] font-medium text-[color:var(--color-fg)]';
const baseTagClass =
  'inline-flex items-center rounded-sm border px-2 py-1.25 font-mono text-[10px] leading-none';
---

<article
  class:list={[
    'flex h-64 flex-col overflow-hidden rounded-md border border-(--color-line-med) bg-transparent p-2 transition-[background-color,border-color,transform] duration-150 ease-out-smooth hover:-translate-y-px hover:bg-(--color-bg-raised) hover:border-[color-mix(in_srgb,var(--card-accent)_18%,var(--color-line-med))] xs:h-63 xs:p-5',
    '[--card-accent:var(--color-info)] [--card-accent-dot:var(--color-info-dot)]',
    '[--card-status-fg:var(--color-ok)] [--card-status-dot:var(--color-ok-dot)]',
    toneClass[entry.tone],
    statusClass[entry.status],
  ]}
>
  <div class="flex min-h-0 flex-1 flex-col">
    <header class="flex items-start gap-1.5">
      <span
        class="inline-flex size-8 shrink-0 items-center justify-center rounded-sm border border-[color-mix(in_srgb,var(--card-accent)_24%,var(--color-line-med))] bg-(--color-bg-raised) font-mono text-[11px] leading-none tracking-[0.14em] text-(--card-accent) uppercase"
        aria-hidden="true"
      >
        {entry.shortCode}
      </span>

      <div class="min-w-0 flex-1">
        <a class="group block max-w-full" href={entry.href} rel="noreferrer" target="_blank">
          <div class="flex flex-wrap items-start gap-x-1 gap-y-0.5">
            <h2
              class="overflow-hidden text-[15px] leading-[1.3] font-medium text-(--color-fg) transition-colors duration-150 ease-out-smooth [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2] group-hover:text-(--card-accent)"
            >
              {entry.name}
            </h2>
            <span class="mt-0.5 inline-flex items-center text-(--card-accent)" aria-hidden="true">
              <ExternalLinkIcon size={13} stroke={1.9} class="block" />
            </span>
            {
              entry.featured ? (
                <span
                  class="mt-0.5 inline-flex items-center text-(--card-accent)"
                  aria-label="推荐"
                  title="推荐"
                >
                  <FeaturedIcon size={13} class="block" />
                </span>
              ) : null
            }
          </div>
          <p
            class="mt-0.75 overflow-hidden text-ellipsis whitespace-nowrap font-mono text-[11px] leading-[1.35] text-(--color-fg-3) transition-colors duration-150 ease-out-smooth group-hover:text-(--card-accent)"
          >
            {entry.domain}
          </p>
        </a>
      </div>
    </header>

    <div class="mt-2 flex min-h-0 flex-1 flex-col">
      <div class="flex min-h-0 flex-1 flex-col">
        <div class="flex h-[3.36rem] items-center overflow-hidden">
          <p
            class="overflow-hidden text-base leading-[1.68] text-(--color-fg-2) [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2]"
          >
            {entry.summary}
          </p>
        </div>

        <div class="my-auto overflow-hidden">
          <ul
            class="flex h-7 flex-nowrap items-center gap-1 overflow-x-auto overflow-y-hidden whitespace-nowrap [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
            aria-label={`${entry.name} 标签`}
          >
            <li>
              <span
                class:list={[
                  baseTagClass,
                  'border-[color-mix(in_srgb,var(--card-accent)_24%,var(--color-line))] text-(--card-accent)',
                ]}
              >
                {entry.primaryTag}
              </span>
            </li>
            {
              entry.subTags.map((tag) => (
                <li>
                  <span class:list={[baseTagClass, 'border-(--color-line) text-(--color-fg-3)']}>
                    {tag}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mt-2 h-19 shrink-0 border-t border-(--color-line) pt-2">
        <div class="flex h-full flex-col">
          <div class="flex min-h-6.5 items-center justify-between gap-2">
            <div class="flex min-w-0 items-center gap-2 overflow-hidden">
              <p
                class="inline-flex shrink-0 items-center gap-1.5 font-mono text-[10px] leading-[1.35] text-(--color-fg-3)"
              >
                <span>加入</span>
                <time datetime={entry.joinedAt}>{entry.joinedLabel}</time>
              </p>

              {
                entry.updatedLabel ? (
                  <p class="inline-flex min-w-0 items-center gap-1.5 overflow-hidden font-mono text-[10px] leading-[1.35] text-(--card-status-fg)">
                    <span
                      class="size-1.5 shrink-0 rounded-full bg-(--card-status-dot)"
                      aria-hidden="true"
                    />
                    <span class="truncate">{entry.updatedLabel}</span>
                  </p>
                ) : null
              }
            </div>

            {
              resourceLinks.length ? (
                <div
                  class="inline-flex shrink-0 items-center gap-1"
                  aria-label={`${entry.name} 资源链接`}
                >
                  {resourceLinks.map(({ href, label, title, Icon }) => (
                    <a
                      class={iconActionClass}
                      href={href}
                      rel="noreferrer"
                      target="_blank"
                      aria-label={label}
                      title={title}
                    >
                      <Icon size={14} stroke={1.8} class="block" />
                    </a>
                  ))}
                </div>
              ) : null
            }
          </div>

          <footer class="mt-auto flex min-h-9 items-end justify-between gap-2">
            <dl class="flex min-w-0 items-end gap-4 overflow-hidden">
              {
                metrics.map(({ label, value }) => (
                  <div class="min-w-18">
                    <dt class={metricLabelClass}>{label}</dt>
                    <dd class={metricValueClass}>{value}</dd>
                  </div>
                ))
              }
            </dl>

            <a
              class="inline-flex min-h-6.5 shrink-0 items-center gap-1 rounded-sm border border-(--color-line-med) px-2.5 py-1 text-[12px] leading-none font-medium text-(--color-fg-2) transition-[background-color,border-color,color] duration-150 ease-out-smooth hover:border-[color-mix(in_srgb,var(--card-accent)_24%,var(--color-line-med))] hover:bg-(--color-bg-raised) hover:text-(--card-accent) focus-visible:outline-none focus-visible:border-(--card-accent-dot)"
              href={detailHref}
            >
              详情
              <ArrowIcon size={13} stroke={1.9} class="block" />
            </a>
          </footer>
        </div>
      </div>
    </div>
  </div>
</article>
