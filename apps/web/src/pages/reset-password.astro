---
import { getAuthErrorMessage } from '@/application/auth/auth-page';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;

const token = Astro.url.searchParams.get('token')?.trim() || '';
const nextPath = Astro.url.searchParams.get('next')?.trim() || null;
const errorMessage = getAuthErrorMessage(Astro.url.searchParams.get('error'));
---

<BaseLayout title="Reset Password | ZhBlogs" showFooter={false}>
  <main class="page-shell auth-shell items-center justify-center">
    <section class="page-stack max-w-md">
      <div class="surface-card space-y-6">
        <div class="page-lead">
          <p class="eyebrow">
            <span class="status-dot" style="--status-dot: var(--color-info-dot)"></span>
            auth / reset password
          </p>
          <h1 class="page-lead-title">重置密码</h1>
        </div>

        {
          errorMessage && (
            <div class="status-panel status-panel-error">
              <p class="status-panel-title">需要处理</p>
              <p class="status-panel-copy">{errorMessage}</p>
            </div>
          )
        }

        {
          token ? (
            <>
              <form action="/auth/password/reset" class="form-stack" method="post">
                <input type="hidden" name="token" value={token} />
                <input type="hidden" name="next" value={nextPath ?? ''} />
                <label class="form-field">
                  <span>新密码</span>
                  <input maxlength="128" minlength="8" name="password" required type="password" />
                </label>
                <label class="form-field">
                  <span>确认新密码</span>
                  <input
                    maxlength="128"
                    minlength="8"
                    name="confirmPassword"
                    required
                    type="password"
                  />
                </label>
                <div class="pt-4">
                  <button class="action-button action-button-primary w-full" type="submit">
                    确认重置密码
                  </button>
                </div>
              </form>

              <div class="flex justify-end pt-4 text-sm">
                <a
                  class="text-(--color-fg-3) underline decoration-[color:var(--color-line-med)] underline-offset-[0.18em] transition hover:text-(--color-fg)"
                  href={`/login${nextPath ? `?next=${encodeURIComponent(nextPath)}` : ''}`}
                >
                  返回登录
                </a>
              </div>
            </>
          ) : (
            <div class="status-panel status-panel-warning">
              <p class="status-panel-title">链接不可用</p>
              <p class="status-panel-copy">缺少重置令牌，请重新申请找回密码。</p>
            </div>
          )
        }
      </div>
    </section>
  </main>
</BaseLayout>
