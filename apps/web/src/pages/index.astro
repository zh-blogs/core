---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="ZhBlogs Web">
  <main class="mx-auto flex w-full max-w-6xl flex-1 items-center px-6 py-16">
    <section class="surface-panel w-full overflow-hidden p-8 md:p-12">
      <div class="grid gap-10 md:grid-cols-[minmax(0,1.3fr)_minmax(20rem,0.9fr)] md:items-end">
        <div class="animate-in fade-in slide-in-from-bottom-4 duration-700">
          <p class="inline-flex items-center gap-2 rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-medium text-sky-700">
            <span class="inline-block h-2 w-2 rounded-full bg-sky-500"></span>
            Astro + Tailwind foundation
          </p>
          <h1 class="mt-5 max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl">
            Web module is ready for the next layer of product work.
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-8 text-slate-600 md:text-lg">
            当前结构已经把 Astro、Tailwind v4 和构建信息页脚收口到一套基础骨架里，
            后续你可以在这个基础上继续拆分业务页面、内容页和交互组件。
          </p>
        </div>

        <div class="animate-in fade-in slide-in-from-bottom-6 duration-700 delay-150">
          <div class="rounded-3xl border border-slate-200 bg-slate-950 p-6 text-sm text-slate-200 shadow-2xl shadow-slate-900/15">
            <p class="font-mono text-xs uppercase tracking-[0.3em] text-slate-400">status</p>
            <div class="mt-4 space-y-3 font-mono text-sm">
              <p class="flex items-center justify-between gap-4">
                <span class="text-slate-400">rendering</span>
                <span class="text-emerald-300">astro</span>
              </p>
              <p class="flex items-center justify-between gap-4">
                <span class="text-slate-400">styling</span>
                <span class="text-cyan-300">tailwind v4</span>
              </p>
              <p class="flex items-center justify-between gap-4">
                <span class="text-slate-400">footer</span>
                <span class="text-amber-300">build metadata</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
