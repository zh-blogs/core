---
import { getCollection } from 'astro:content';

import { readCurrentAnnouncement } from '@/application/announcement/announcement.server';
import { readCommunityRoles } from '@/application/community/community.server';
import { readHomeSummary } from '@/application/home/home.server';
import { readPublicSites, shuffleSites } from '@/application/site/site-public.server';
import HomeCommunityDocs from '@/components/home/HomeCommunityDocs.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import HomeProjectBlogs from '@/components/home/HomeProjectBlogs.astro';
import HomeRandomBlogs from '@/components/home/HomeRandomBlogs.svelte';
import PublicHeader from '@/components/public-header/PublicHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { groupDocsByCategory } from '@/shared/data/doc-categories';

export const prerender = false;

const formatDate = (value: Date | string | null): string => {
  const target = value instanceof Date ? value : value ? new Date(value) : null;

  if (!target) {
    return '';
  }

  return target.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
};

const projectBlogs = (await getCollection('blogs')).sort(
  (left, right) => right.data.create_time.getTime() - left.data.create_time.getTime(),
);
const docs = (await getCollection('docs')).sort(
  (left, right) => right.data.create_time.getTime() - left.data.create_time.getTime(),
);
const docGroups = groupDocsByCategory(docs);
const publicSites = await readPublicSites();
const communityRoles = await readCommunityRoles();

const fallbackSummary = {
  totalSites: publicSites.length,
  featuredSites: publicSites.filter((entry) => entry.featured).length,
  todayUpdates: publicSites.filter(
    (entry) => entry.updatedLabel?.includes('今天') || entry.updatedLabel?.includes('1 天前'),
  ).length,
};

const summary = await readHomeSummary(fallbackSummary);
const leadAnnouncement = await readCurrentAnnouncement();
const leadAnnouncementDate = leadAnnouncement?.publishTime
  ? formatDate(leadAnnouncement.publishTime)
  : '';
const randomBlogs = shuffleSites(publicSites).slice(0, 6);
const recentProjectBlogs = projectBlogs.slice(0, 3).map((entry) => ({
  id: entry.id,
  title: entry.data.title,
  description: entry.data.description,
  tags: entry.data.tags,
  dateLabel: formatDate(entry.data.create_time),
}));

const homeDescription = '尝试收集并链接所有的个人博客站点';
---

<BaseLayout title="集博栈" description={homeDescription}>
  <PublicHeader currentPath={Astro.url.pathname} />

  <main class="flex-1">
    <div
      class="mx-auto flex w-full max-w-368 flex-col gap-10 px-3.5 py-6 xs:px-4 sm:px-6 lg:gap-12 lg:px-8 lg:py-8"
    >
      <HomeHero
        leadAnnouncement={leadAnnouncement}
        leadAnnouncementDate={leadAnnouncementDate}
        summary={summary}
      />

      <HomeRandomBlogs client:load randomBlogs={randomBlogs} />

      <HomeProjectBlogs blogs={recentProjectBlogs} />

      <HomeCommunityDocs communityRoles={communityRoles} docGroups={docGroups} />
    </div>
  </main>
</BaseLayout>
