---
import { getAuthErrorMessage, getAuthStatusMessage } from '@/application/auth/auth-page';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;

const nextPath = Astro.url.searchParams.get('next')?.trim() || null;
const statusMessage = getAuthStatusMessage(Astro.url.searchParams.get('status'));
const errorMessage = getAuthErrorMessage(Astro.url.searchParams.get('error'));
---

<BaseLayout title="Forgot Password | ZhBlogs" showFooter={false}>
  <main class="page-shell auth-shell items-center justify-center">
    <section class="page-stack max-w-md">
      <div class="surface-card space-y-6">
        <div class="page-lead">
          <p class="eyebrow">
            <span class="status-dot" style="--status-dot: var(--color-info-dot)"></span>
            auth / forgot password
          </p>
          <h1 class="page-lead-title">找回密码</h1>
        </div>

        {
          statusMessage && (
            <div class="status-panel status-panel-success">
              <p class="status-panel-title">操作已完成</p>
              <p class="status-panel-copy">{statusMessage}</p>
            </div>
          )
        }
        {
          errorMessage && (
            <div class="status-panel status-panel-error">
              <p class="status-panel-title">需要处理</p>
              <p class="status-panel-copy">{errorMessage}</p>
            </div>
          )
        }

        <form action="/auth/password/forgot" class="form-stack" method="post">
          <input type="hidden" name="next" value={nextPath ?? ''} />
          <label class="form-field">
            <span>邮箱</span>
            <input name="email" required type="email" />
          </label>
          <div class="pt-4">
            <button class="action-button action-button-primary w-full" type="submit">
              发送重置邮件
            </button>
          </div>
        </form>

        <div class="flex justify-end text-sm">
          <a
            class="text-(--color-fg-3) underline decoration-(--color-line-med) underline-offset-[0.18em] transition hover:text-(--color-fg)"
            href={`/login${nextPath ? `?next=${encodeURIComponent(nextPath)}` : ''}`}
          >
            返回登录
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
