---
import { getCollection } from 'astro:content';

import { formatZhDate } from '@/application/content/content.date';
import {
  buildReferenceLabelMap,
  mapReferenceLabels,
} from '@/application/content/content.references';
import PublicHeader from '@/components/public-header/PublicHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const entries = (await getCollection('blogs')).sort(
  (left, right) => right.data.create_time.getTime() - left.data.create_time.getTime(),
);
const members = await getCollection('members');
const groups = await getCollection('group');

const memberNameById = buildReferenceLabelMap(
  members,
  (member) => member.id,
  (member) => member.data.nickname || member.id,
);
const groupNameById = buildReferenceLabelMap(
  groups,
  (group) => group.id,
  (group) => group.data.name,
);

const blogCards = entries.map((entry) => ({
  ...entry,
  createDate: formatZhDate(entry.data.create_time),
  tagLabels: entry.data.tags.map((tag) => `#${tag}`),
  editorNames: mapReferenceLabels(entry.data.editors, memberNameById),
  groupNames: mapReferenceLabels(entry.data.groups, groupNameById),
  routePath: `/blog/${entry.id}`,
}));

const metaValueClass = 'text-xs text-(--color-fg-2)';
const metaLabelClass =
  'shrink-0 font-mono text-[10px] uppercase tracking-[0.16em] text-(--color-fg-3)';
const mobileMetaRowClass = 'flex items-center gap-2 overflow-x-auto whitespace-nowrap';
const desktopMetaRowClass =
  'flex items-center justify-start gap-2 overflow-x-auto whitespace-nowrap lg:justify-end';
const desktopMetaValuesClass =
  'flex min-w-0 flex-1 items-center justify-start gap-2 whitespace-nowrap lg:justify-end';
---

<BaseLayout title="项目博客 | 集博栈">
  <PublicHeader currentPath={Astro.url.pathname} />

  <main class="flex-1">
    <div
      class="mx-auto flex w-full max-w-368 flex-col gap-8 px-3.5 py-6 xs:px-4 sm:px-6 lg:px-8 lg:py-8"
    >
      <section class="border-b border-(--color-line) pb-8">
        <p
          class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-red-700 dark:text-red-400"
        >
          项目博客
        </p>
        <h1 class="mt-4 text-[clamp(2.4rem,6vw,4rem)] leading-none tracking-[-0.04em]">最近更新</h1>
      </section>

      <section class="grid gap-4">
        {
          blogCards.map((entry) => (
            <a
              class="group block border-b border-(--color-line) py-6 transition first:pt-1 hover:border-red-700/35 dark:hover:border-red-400/35"
              href={`/blog/${entry.id}`}
            >
              <div class="grid gap-5 lg:grid-cols-[20rem_0.375rem_minmax(0,1fr)] lg:items-center lg:gap-x-6">
                <div class="min-w-0 lg:order-3 lg:pl-6 lg:self-center">
                  <h2 class="text-[1.45rem] leading-tight tracking-[-0.02em] text-(--color-fg) transition group-hover:text-red-700 dark:group-hover:text-red-400">
                    {entry.data.title}
                  </h2>
                  <p class="mt-3 text-sm leading-7 text-(--color-fg-2)">{entry.data.description}</p>

                  <div class="mt-5 flex items-center gap-2 overflow-x-auto whitespace-nowrap font-mono text-[11px] uppercase tracking-[0.16em] text-(--color-fg-3)">
                    <span>{entry.createDate}</span>
                    <span class="h-1 w-1 rounded-full bg-(--color-line-med)" />
                    <span>{entry.data.category}</span>
                    <span class="h-1 w-1 rounded-full bg-(--color-line-med)" />
                    <span class="text-[10px] tracking-[0.14em]">{entry.routePath}</span>
                  </div>
                </div>

                <span
                  aria-hidden="true"
                  class="hidden lg:order-2 lg:block lg:h-full lg:min-h-28 lg:w-1.5 lg:rounded-full lg:bg-red-700/70 dark:lg:bg-red-400/70"
                />

                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-(--color-fg-2) lg:hidden">
                  <div class="basis-full xs:basis-auto">
                    <div class={mobileMetaRowClass}>
                      <span class={metaLabelClass}>标签</span>
                      {entry.tagLabels.map((value) => (
                        <span class={metaValueClass}>{value}</span>
                      ))}
                    </div>
                  </div>

                  <div class="basis-full xs:basis-auto">
                    <div class={mobileMetaRowClass}>
                      <span class={metaLabelClass}>协同编辑</span>
                      {entry.editorNames.map((value) => (
                        <span class={metaValueClass}>{value}</span>
                      ))}
                      <span class="h-1 w-1 rounded-full bg-(--color-line-med)" />
                      <span class={metaLabelClass}>发布组别</span>
                      {entry.groupNames.map((value) => (
                        <span class={metaValueClass}>{value}</span>
                      ))}
                    </div>
                  </div>
                </div>

                <dl class="hidden gap-2.5 text-sm text-(--color-fg-2) lg:order-1 lg:grid lg:pr-6 lg:self-center">
                  <div class={desktopMetaRowClass}>
                    <dd class={desktopMetaValuesClass}>
                      {entry.tagLabels.map((value) => (
                        <span class={metaValueClass}>{value}</span>
                      ))}
                    </dd>
                  </div>

                  <div class={desktopMetaRowClass}>
                    <dd class={desktopMetaValuesClass}>
                      {entry.editorNames.map((value) => (
                        <span class={metaValueClass}>{value}</span>
                      ))}
                    </dd>
                    <dt class={metaLabelClass}>协同编辑</dt>
                  </div>

                  <div class={desktopMetaRowClass}>
                    <dd class={desktopMetaValuesClass}>
                      {entry.groupNames.map((value) => (
                        <span class={metaValueClass}>{value}</span>
                      ))}
                    </dd>
                    <dt class={metaLabelClass}>发布组别</dt>
                  </div>
                </dl>
              </div>

              <div class="mt-4 flex items-center justify-end text-(--color-fg-3) transition group-hover:text-red-700 dark:group-hover:text-red-400">
                <span aria-hidden="true" class="text-lg leading-none">
                  →
                </span>
              </div>
            </a>
          ))
        }
      </section>
    </div>
  </main>
</BaseLayout>
