---
import { fetchApiJson } from '@/application/api/api.server';
import type { RestoreTargetResult } from '@/application/site-submission/site-submission.service';
import PublicHeader from '@/components/public-header/PublicHeader.astro';
import SiteRestoreSubmissionForm from '@/components/site-submission/SiteRestoreSubmissionForm.svelte';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;

const siteId = Astro.url.searchParams.get('site_id') ?? '';
const restoreTargetPayload =
  siteId.trim().length > 0
    ? await fetchApiJson<{
        ok: boolean;
        data: RestoreTargetResult;
      }>(`/api/sites/${encodeURIComponent(siteId)}/restorations/target`)
    : null;
const restoreTarget = restoreTargetPayload?.ok ? restoreTargetPayload.data : null;
---

<BaseLayout title="恢复站点 | 集博栈">
  <PublicHeader currentPath={Astro.url.pathname} />

  <main class="flex-1">
    <div class="mx-auto w-full max-w-220 px-3.5 py-6 xs:px-4 sm:px-6 lg:px-8 lg:py-8">
      <section class="space-y-3 pb-6">
        <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-(--color-fg-3)">
          site restore
        </p>
        <h1 class="text-3xl tracking-[-0.04em] text-(--color-fg)">恢复已下线站点</h1>
        <p class="max-w-3xl text-sm leading-7 text-(--color-fg-2)">
          当前页面只处理已经下线的站点恢复申请，请结合站点当前状态填写恢复说明，以便审核。
        </p>
      </section>

      <SiteRestoreSubmissionForm client:load target={restoreTarget} />
    </div>
  </main>
</BaseLayout>
