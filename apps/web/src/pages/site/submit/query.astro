---
import PublicHeader from '@/components/public-header/PublicHeader.astro';
import SiteSubmissionWorkspace from '@/components/site-submission/SiteSubmissionWorkspace.svelte';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;

const initialAuditId = Astro.url.searchParams.get('audit_id') ?? '';
---

<BaseLayout title="查询审核结果 | 集博栈">
  <PublicHeader currentPath={Astro.url.pathname} />

  <main class="flex-1">
    <div class="mx-auto w-full max-w-368 px-3.5 py-6 xs:px-4 sm:px-6 lg:px-8 lg:py-8">
      <SiteSubmissionWorkspace client:load activePage="query" initialAuditId={initialAuditId} />
    </div>
  </main>
</BaseLayout>
