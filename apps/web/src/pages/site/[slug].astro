---
export const prerender = false;

import { IconArrowLeft } from '@tabler/icons-svelte-runes';

import {
  fetchSiteArticles,
  fetchSiteChecks,
  fetchSiteDetail,
} from '@/application/site/site-directory.server';
import PublicHeader from '@/components/public-header/PublicHeader.astro';
import { resolveSiteDetailDescription } from '@/components/site/site-detail.shared';
import SiteDetailPage from '@/components/site/SiteDetailPage.svelte';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildSiteOgImagePath } from '@/shared/site-og';

const slug = Astro.params.slug ?? '';
const detail = slug ? await fetchSiteDetail(slug) : null;

if (!detail) {
  Astro.response.status = 404;
}

const articles = detail
  ? ((await fetchSiteArticles(detail.slug, 1, 20)) ?? {
      items: [],
      pagination: {
        page: 1,
        pageSize: 20,
        totalItems: 0,
        totalPages: 1,
      },
    })
  : {
      items: [],
      pagination: {
        page: 1,
        pageSize: 20,
        totalItems: 0,
        totalPages: 1,
      },
    };

const checks = detail
  ? ((await fetchSiteChecks(detail.slug, 1, 20)) ?? {
      items: [],
      pagination: {
        page: 1,
        pageSize: 20,
        totalItems: 0,
        totalPages: 1,
      },
    })
  : {
      items: [],
      pagination: {
        page: 1,
        pageSize: 20,
        totalItems: 0,
        totalPages: 1,
      },
    };

const ArrowLeftIcon = IconArrowLeft;
const detailDescription = detail ? resolveSiteDetailDescription(detail.sign) : '未找到对应站点。';
const detailOgImagePath = detail ? buildSiteOgImagePath(detail.slug) : undefined;
---

<BaseLayout
  title={detail ? `${detail.name} | 集博栈` : '站点不存在 | 集博栈'}
  description={detailDescription}
  canonicalPath={`/site/${slug}`}
  imagePath={detailOgImagePath}
  imageAlt={detail ? `${detail.name} 的站点详情分享卡片` : undefined}
  robots={detail ? undefined : 'noindex, nofollow'}
  publishedTime={detail?.joinTime}
  modifiedTime={detail?.updateTime}
>
  <PublicHeader currentPath={Astro.url.pathname} activePrimaryKey="directory" />

  <main class="page-shell">
    <div class="page-stack">
      <section class="page-section pt-2">
        <a
          class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-(--color-fg-3) transition hover:text-(--color-fg)"
          href="/site"
        >
          <ArrowLeftIcon size={14} stroke={1.9} />
          返回站点目录
        </a>
      </section>

      {
        detail ? (
          <SiteDetailPage
            client:load
            detail={detail}
            initialArticles={articles}
            initialChecks={checks}
          />
        ) : (
          <section class="page-section">
            <div class="rounded-[6px] border border-(--color-line) bg-(--color-bg) px-5 py-10 text-sm text-(--color-fg-2)">
              未找到对应站点。
            </div>
          </section>
        )
      }
    </div>
  </main>
</BaseLayout>
